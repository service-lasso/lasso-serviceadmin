{
  "id": "secrets-broker",
  "name": "Secrets Broker",
  "description": "Secret-resolution service for provider credentials and runtime configuration.",
  "enabled": true,
  "version": "0.1.0",
  "logoutput": true,
  "icon": "key-round",
  "servicetype": 35,
  "servicelocation": 10,
  "logo": "./logo.svg",
  "logs": {
    "default": {
      "path": "./service.log"
    }
  },
  "actions": {
    "install": {
      "description": "Install or refresh the Secrets Broker runtime payload."
    },
    "config": {
      "description": "Materialize the effective secrets-broker configuration."
    },
    "start": {
      "description": "Start the Secrets Broker service."
    },
    "stop": {
      "description": "Stop the Secrets Broker gracefully."
    }
  },
  "execconfig": {
    "serviceorder": 35,
    "serviceport": 8083,
    "execcwd": ".",
    "executable": "secrets-broker",
    "env": {
      "SECRETS_PROVIDER": "local"
    },
    "depend_on": [
      "traefik"
    ],
    "healthcheck": {
      "type": "process"
    }
  }
}
